rel icfg_edge(X, Y, Ctx, Ctx) :- cfg_edge(X, Y, Ctx)
rel icfg_edge(CallSite, Callee, Caller, Callee) :- calls(Caller, Callee, CallSite)
rel icfg_edge(Retsite, Y, Caller, Callee) :-
    calls(Caller, Callee, Callsite),
    returns(Callee, Retsite),
    cfg_edge(Callsite, Y, Caller)

type icfg_path(bound X: u32, Y: u32, bound XCtx: u32, YCtx: u32)
rel icfg_path(X, Y, XCtx, YCtx) :- icfg_edge(X, Y, XCtx, YCtx)
rel icfg_path(X, Y, XCtx, YCtx) :-
    icfg_edge(X, Z, XCtx, InterCtx),
    icfg_path(Z, Y, InterCtx, YCtx)

rel prob_icfg_edge(X, Y, Ctx, Ctx) :- prob_cfg_edge(X, Y, Ctx)
rel prob_icfg_edge(CallSite, Callee, Caller, Callee) :- calls(Caller, Callee, CallSite)
rel prob_icfg_edge(Retsite, Y, Caller, Callee) :-
    calls(Caller, Callee, Callsite),
    returns(Callee, Retsite),
    prob_cfg_edge(Callsite, Y, Caller)

type prob_icfg_path(bound X: u32, Y: u32, bound XCtx: u32, YCtx: u32)
rel prob_icfg_path(X, Y, XCtx, YCtx) :- prob_icfg_edge(X, Y, XCtx, YCtx)
rel prob_icfg_path(X, Y, XCtx, YCtx) :-
    prob_icfg_edge(X, Z, XCtx, InterCtx),
    prob_icfg_path(Z, Y, InterCtx, YCtx)

rel icfg_ctx_insensitive_edge(X, Y) :- cfg_edge(X, Y, _)
rel icfg_ctx_insensitive_edge(X, Y) :- calls(_, Y, X)
rel icfg_ctx_insensitive_edge(X, Y) :-
    calls(_, Callee, Callsite),
    returns(Callee, X),
    cfg_edge(Callsite, Y, _)

type icfg_ctx_insensitive_path(bound X: u32, Y: u32)
rel icfg_ctx_insensitive_path(X, Y) :- icfg_ctx_insensitive_edge(X, Y)
rel icfg_ctx_insensitive_path(X, Y) :- 
    icfg_ctx_insensitive_edge(X, Z), 
    icfg_ctx_insensitive_path(Z, Y)

type on_any_icfg_path(bound Z: u32, bound X: u32, bound Y: u32)
rel on_any_icfg_path(Z, X, Y) :- 
    icfg_ctx_insensitive_path(X,Z), 
    icfg_ctx_insensitive_path(Z,Y)

