type program(pgm: String)
type output(result: bool)

@gpt_extract_info(
  header="""
You are an experienced program security analyzer.
Given the following Java program, please analyze it for taint analysis.
Extract the dataflow edges, sources, sanitizers, and sinks in the program.
When a variable is assigned multiple times, please label each variable using `var#n` where `n` represents its n-th version.
When a function call to a specified function is happening, construct the dataflow stepping into and out of the function.
Sources are usually statements attempting to obtain malicious information from network request, or creation of random values.
The sinks are usually directly related to vulnerability, such as executing OS command, traversing a path,
creating file, writing to network response, or running a SQL query.
Please output everything in JSON.
  """,
  prompts=[
    "What are the dataflow edges in the program where taint information may pass through?",
    "What are the sources of taint information in the program?",
    // "What are the sanitizers that stop the propagation of taint information?",
    "What are the sinks where potential taint information may cause harm to the system?",
  ],
  examples=[
    (
      ["""
public void doPost(HttpServletRequest request, HttpServletResponse response) {
  String param = request.getParam("BenchmarkTest00657");
  String bar = "safe!";
  java.util.HashMap<String, Object> map27260 = new java.util.HashMap<String, Object>();
  map27260.put("keyA-27260", "a_Value");
  map27260.put("keyB-27260", param);
  map27260.put("keyC", "another_Value");
  bar = (String) map27260.get("keyB-27260");
  bar = (String) map27260.get("keyA-27260");
  String cmd = "echo";
  Runtime r = Runtime.getRuntime();
  Process p = r.exec(cmd + bar);
}
      """],
      [
        [
          ("param = request.getParam(\"BenchmarkTest00657\")", "map27260.put(\"keyB-27260\", param)"),
          ("map27260.put(\"keyB-27260\", param)", "bar#1 = (String) map27260.get(\"keyB-27260\")"),
          ("map27260.put(\"keyA-27260\", \"a_Value\")", "bar#2 = (String) map27260.get(\"keyA-27260\")"),
          ("bar#2 = (String) map27260.get(\"keyA-27260\")", "p = r.exec(cmd + bar)")
        ],
        [
          ("param = request.getParam(\"BenchmarkTest00657\")",)
        ],
        // [],
        [
          ("p = r.exec(cmd + bar)"),
        ]
      ]
    ),
