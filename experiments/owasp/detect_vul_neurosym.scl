//       response.getWriter().write(bar, 0, length);
//   }
// }
//       """],
//       [
//         [
//           ("scr = new org.owasp.benchmark.helpers.SeparateClassRequest(request)", "param = scr.getTheParameter(\"BenchmarkTest00651\")"),
//           ("param = scr.getTheParameter(\"BenchmarkTest00651\")", "bar = param"),
//           ("bar = param", "response.getWriter().write(bar, 0, length)")
//         ],
