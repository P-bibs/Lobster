// Global Constants
rel possible_pairing = {('A', 'U'), ('U', 'A'), ('C', 'G'), ('G', 'C'), ('G', 'U'), ('U', 'G')}

// Input:
// The RNA sequence
type rna(seq: String)

// Knudsen–Hein grammar (simplified)
//   S → L | LS
//   L → s | dSd
//
// The set of non-terminal symbols in the grammer is {S, L}
type NonTermSymbol = S | L

// The product rules in Knudsen–Hein grammar
type Rule = S2L    // S -> L
          | S2LS   // S -> LS
          | L2s    // L -> s
          | L2dSd  // L -> dSd

// The probability of applying a product rule on subsequence [i, j)
// This is an input from a neural network
type prod_rule_prob(rule: Rule)

rel prod_rule_prob = {
  1.0::S2L,   // 55
  1.0::S2LS,  // 56
  1.0::L2s,   // 57
  1.0::L2dSd, // 58
}

type prob_rule_prob(i: usize, j: usize, r: Rule)

type bond(i: usize, j: usize)

// Outputs
type ss(ss: String) // The secondary structure in dot-bracket form
type pair(i: usize, j: usize) // Whether there exists a pair between i and j

// Extracting basic information
rel base(id, c) = rna(seq) and string_chars(seq, id, c) // {(0, 'A'), (1, 'C'), (2, 'G'), ...}
rel len($string_length(seq)) = rna(seq)

// Whether a subsequence (i, j) is matched on a non-terminal symbol
type matched(bound i: usize, j: usize, sym: NonTermSymbol, seq: String)

// The semantics of each production rule
rel matched(i, j, S, seq) = matched(i, j, L, seq) and prod_rule_prob(S2L)
rel matched(i, k, S, s1 + s2) = matched(i, j, L, s1) and matched(j, k, S, s2) and prod_rule_prob(S2LS)
rel matched(id, id + 1, L, ".") = base(id, _) and prod_rule_prob(L2s)
rel matched(i, j + 1, L, $format("({})", subseq)) = base(i, xi) and matched(i + 1, j, S, subseq) and base(j, xj) and possible_pairing(xi, xj) and prod_rule_prob(L2dFd) and bond(i, j)

// The extracted secondary structure
rel ss(ss) = len(l) and matched(0, l, S, ss)

// Queries
query ss
query pair
