// Global Constants
rel possible_pairing = {('A', 'U'), ('U', 'A'), ('C', 'G'), ('G', 'C')}

// Input:
// The RNA sequence
type rna(seq: String)

// Knudsen–Hein grammar (simplified)
//   S → L | LS
//   L → s | dSd
//
// The set of non-terminal symbols in the grammer is {S, L}
type NonTermSymbol = S | L

// The product rules in Knudsen–Hein grammar
type Rule = S2L    // S -> L
          | S2LS   // S -> LS
          | L2s    // L -> s
          | L2dSd  // L -> dSd

// The probability of applying a product rule on subsequence [i, j)
// This is an input from a neural network
type prod_rule_prob(rule: Rule)

rel prod_rule_prob = {
  0.1::S2L,
  0.3::S2LS,
  0.4::L2s,
  0.2::L2dSd,
}

// Outputs
type ss() // The secondary structure in dot-bracket form
type pair(i: usize, j: usize) // Whether there exists a pair between i and j

// Extracting basic information
rel base(id, c) = rna(seq) and string_chars(seq, id, c) // {(0, 'A'), (1, 'C'), (2, 'G'), ...}
rel len($string_length(seq)) = rna(seq)

// Whether a subsequence (i, j) is matched on a non-terminal symbol
type matched(bound i: usize, j: usize, sym: NonTermSymbol)

// The semantics of each production rule
/* S -> L   */ rel matched(i, j, S) = matched(i, j, L) and prod_rule_prob(S2L)
/* S -> LS  */ rel matched(i, k, S) = matched(i, j, L) and matched(j, k, S) and prod_rule_prob(S2LS)
/* L -> s   */ rel matched(id, id + 1, L) = base(id, _) and prod_rule_prob(L2s)
/* L -> dSd */ rel { matched(i, j + 1, L), pair(i, j) } = base(i, xi) and matched(i + 1, j, S) and base(j, xj) and possible_pairing(xi, xj) and prod_rule_prob(L2dFd)

// The extracted secondary structure
rel ss() = len(l) and matched(0, l, S)

@goal
rel goal() = len(l) and matched(0, l, S)

// Queries
query ss
query pair
