rel sub_match(t0, t0, v0, v1) = single_match(t0, v0, v1)
rel sub_match(t0, t0, v0, v2) = sub_match(t0, t0, v0, v1), single_match(t0, v1, v2)
rel sub_match(t0, t1, v0, v2) = sub_match(t0, t1 - 1, v0, v1), single_match(t1, v1, v2)

